{
	"name": "clean-architecture",
	"version": "0.1.0",
	"description": "Educational reference for Clean Architecture / Ports & Adapters / DDD in Node.js + TypeScript (ESM). Demonstrates the layered structure (domain, application, infrastructure, presentation), use-case decorators, sagas, CQRS projection, and architectural fitness tests.",
	"keywords": [
		"clean-architecture",
		"hexagonal",
		"ports-and-adapters",
		"DDD",
		"TypeScript",
		"educational",
		"reference",
		"Node.js",
		"ESM",
		"Vitest",
		"XO",
		"Prettier"
	],
	"homepage": "https://github.com/sebastian-suarez/Clean-architecture#readme",
	"bugs": {
		"url": "https://github.com/sebastian-suarez/Clean-architecture/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sebastian-suarez/Clean-architecture.git"
	},
	"license": "MIT",
	"author": "Sebastian Suarez <261091557+sebastian-suarez@users.noreply.github.com> (https://www.sebastiansuarez.dev)",
	"type": "module",
	"imports": {
		"#src/*": "./src/*",
		"#domain/*": "./src/domain/*",
		"#application/*": "./src/application/*",
		"#infrastructure/*": "./src/infrastructure/*",
		"#presentation/*": "./src/presentation/*",
		"#tests/*": "./tests/*"
	},
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"start": "tsx ./src/index.ts",
		"serve": "tsx ./src/server.ts",
		"worker": "tsx ./src/worker.ts",
		"test": "vitest",
		"lint": "xo --fix",
		"format": "prettier --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^25.6.0",
		"dotenv": "^17.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.4",
		"xo": "^1.2.3"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.0",
		"hono": "^4.12.15"
	}
}
